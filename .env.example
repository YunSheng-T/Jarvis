# Copy to .env and fill in. Never commit .env.
# All keys are optional in Phase 0 (skeleton); required from Phase 1 onward.

# --- LLM ---
# OpenAI is optional. ChatGPT subscriptions and API billing are separate.
OPENAI_API_KEY=
JARVIS_LLM_MODEL=gpt-4o-mini
# Optional: point to a local Ollama-compatible endpoint
# JARVIS_LLM_BASE_URL=http://127.0.0.1:11434/v1

# Volcano Engine Ark Agent Plan (recommended cloud backend for this host).
# Create the key in the Ark console, then copy the exact base URL and model ID
# shown by your Agent Plan's "OpenAI SDK" API reference. Do not use the normal
# pay-as-you-go Ark endpoint unless that is what you intend to be billed for.
# ARK_API_KEY=
# JARVIS_LLM_BASE_URL=
# JARVIS_LLM_MODEL=

# --- TTS (optional cloud) ---
ELEVENLABS_API_KEY=
JARVIS_TTS_VOICE=

# --- Runtime ---
JARVIS_LOG_LEVEL=INFO
JARVIS_ENV=dev
